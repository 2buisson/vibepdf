<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="vibepdf.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:vibepdf"
    xmlns:models="using:vibepdf.Models"
    xmlns:strings="using:vibepdf.Strings"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Vibe PDF">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <!-- Content extends under the title bar so the sidebar's tinted background
         reaches the very top of the window. Row 0 is the title bar strip; row 1
         holds the app content. The sidebar background spans both rows. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="350" MinWidth="200" MaxWidth="600" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar background: spans the title bar row so the tinted backdrop
             runs edge-to-edge from the top of the window. -->
        <Border
            Grid.Row="0"
            Grid.RowSpan="2"
            Grid.Column="0"
            Background="{ThemeResource SolidBackgroundFillColorBaseAltBrush}">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
        </Border>

        <!-- Sidebar content sits below the title bar (row 1). -->
        <Grid Grid.Row="1" Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- File-list command bar: Add acts on the list below.
                 Always visible (even when empty) so the first file can be added.
                 Disabled state comes from the bound commands' CanExecute. -->
            <CommandBar
                Grid.Row="0"
                Background="Transparent"
                IsOpen="False"
                DefaultLabelPosition="Right"
                OverflowButtonVisibility="Collapsed"
                HorizontalAlignment="Left">
                <AppBarButton
                    Label="Add PDF(s)"
                    Command="{x:Bind ViewModel.AddFilesCommand, Mode=OneTime}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Add" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>

            <!-- File list + empty placeholder (overlapping, visibility-toggled) -->
            <Grid Grid.Row="1">
                <ListView
                    x:Name="FileListView"
                    ItemsSource="{x:Bind ViewModel.Files, Mode=OneWay}"
                    SelectionMode="Single"
                    SelectedItem="{x:Bind ViewModel.SelectedFile, Mode=TwoWay}"
                    CanDragItems="{x:Bind ViewModel.CanReorderFiles, Mode=OneWay}"
                    AllowDrop="{x:Bind ViewModel.CanReorderFiles, Mode=OneWay}"
                    CanReorderItems="{x:Bind ViewModel.CanReorderFiles, Mode=OneWay}"
                    Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.HasFiles), Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:PdfFileItem">
                            <StackPanel Padding="4,8">
                                <TextBlock
                                    Text="{x:Bind DisplayName, Mode=OneTime}"
                                    Style="{StaticResource BodyTextBlockStyle}"
                                    TextTrimming="CharacterEllipsis" />
                                <TextBlock
                                    Text="{x:Bind local:MainWindow.FormatStatus(Status, PageCount), Mode=OneWay}"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{x:Bind local:MainWindow.StatusForeground(Status), Mode=OneWay}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Text="{x:Bind strings:UiStrings.EmptyFileListPlaceholder}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Visibility="{x:Bind local:MainWindow.BoolToVisibilityInverse(ViewModel.HasFiles), Mode=OneWay}" />
            </Grid>

            <!-- Remove acts on the selected file in the list above. -->
            <CommandBar
                Grid.Row="2"
                Background="Transparent"
                IsOpen="False"
                DefaultLabelPosition="Collapsed"
                OverflowButtonVisibility="Collapsed"
                HorizontalAlignment="Left">
                <AppBarButton
                    Label="Remove"
                    Command="{x:Bind ViewModel.RemoveCommand, Mode=OneTime}">
                    <AppBarButton.Icon>
                        <SymbolIcon Symbol="Delete" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </CommandBar>
        </Grid>

        <!-- GridSplitter (row 1 only, so it never overlaps the title bar strip) -->
        <Border
            x:Name="GridSplitter"
            Grid.Row="1"
            Grid.Column="1"
            Width="8"
            Background="Transparent"
            PointerEntered="GridSplitter_PointerEntered"
            PointerExited="GridSplitter_PointerExited"
            PointerPressed="GridSplitter_PointerPressed"
            PointerMoved="GridSplitter_PointerMoved"
            PointerReleased="GridSplitter_PointerReleased" />

        <!-- Preview panel: preview content (row 0), merge banners (row 1),
             action bar (row 2). The info bar sits directly above the action bar. -->
        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 1: determinate merge progress bar, sitting directly above the
                 action bar. The merge result is shown in a modal ContentDialog. -->
            <StackPanel Grid.Row="1" Spacing="4" Padding="16,0,16,8">
                <ProgressBar
                    Minimum="0" Maximum="100"
                    Value="{x:Bind ViewModel.MergeProgress, Mode=OneWay}"
                    Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.IsProgressVisible), Mode=OneWay}" />
            </StackPanel>

            <!-- Row 0: preview content (image card / placeholder, overlapping) -->
            <!-- Valid file: first-page image centered in a 300px card -->
            <Border
                Grid.Row="0"
                Width="300"
                Padding="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Translation="0,0,32"
                Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.ShowPreviewImage), Mode=OneWay}">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <Image
                    Source="{x:Bind ViewModel.PreviewImage, Mode=OneWay}"
                    Stretch="Uniform" />
            </Border>

            <TextBlock
                Grid.Row="0"
                Text="{x:Bind ViewModel.PreviewPlaceholderText, Mode=OneWay}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Visibility="{x:Bind local:MainWindow.BoolToVisibility(ViewModel.ShowPreviewPlaceholder), Mode=OneWay}" />

            <!-- Row 2: Action bar -->
            <Grid Grid.Row="2" Padding="16,8">
                <StackPanel
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
                    <!-- Add PDF(s) now lives in the file-list CommandBar. -->
                    <!-- Border wrapper stays hit-test-visible so the disabled-Merge tooltip
                         (MC-10/11/12) renders; WinUI does not show a tooltip on a disabled Button. -->
                    <Border
                        ToolTipService.ToolTip="{x:Bind ViewModel.MergeDisabledReason, Mode=OneWay}"
                        Background="Transparent">
                        <Button
                            Content="Merge"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.MergeCommand, Mode=OneTime}" />
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Title bar drag region: a transparent strip across the top, laid over
             the sidebar background and preview. The system caption buttons float
             at the right; SetTitleBar() in code-behind makes this area draggable. -->
        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="3"
            Background="Transparent">
            <TextBlock
                Text="{x:Bind strings:UiStrings.AppTitle}"
                VerticalAlignment="Center"
                Margin="16,0,0,0"
                Style="{StaticResource CaptionTextBlockStyle}" />
        </Grid>
    </Grid>
</Window>
